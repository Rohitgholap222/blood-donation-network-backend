# Ignore build artifacts
target/
!target/*.jar

# Ignore git
.git/
.gitignore

# Ignore local environment files
.env
.env.*

# Ignore IDE settings
.idea/
.vscode/
*.iml

# Ignore logs
*.log
logs/

# Ignore documentation
*.md
HELP.md

# Ignore OS files
.DS_Store
Thumbs.db

# Do NOT ignore pom.xml or src/ (these are needed for the build)
# pom.xml
# src/
